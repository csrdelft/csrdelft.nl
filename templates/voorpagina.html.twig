{% extends 'base.html.twig' %}

{% block titel %}Vereniging van Christenstudenten{% endblock %}



{% block body_inner %}
	<style>

		#footer {
		.inner,
		h2,
		a,
		label {
		color: black;
		}

		a {
		border-bottom: dotted 1px $tekstdonker;
		text-decoration: none;
		&:hover {
		border-bottom-color: transparent;
		color: #ffffff !important;
		}
		}

		iframe {
		width: 100%;
		}

		input,
		textarea {
		color: #11273a !important;
		}

		.inner {
		padding: 5em 0 3em 0;
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		margin: 0 auto;
		width: 100%;

		& > * {
		width: 100%;
		}

		form {
		margin: 0 3em 0 0;
		width: calc(50% - 1.5em);
		}

		.contact {
		width: calc(50% - 1.5em);

		&.zonder-interesseformulier {
		width: 100%;
		}
		}

		.copyright,
		.sponsors {
			border-top: solid 2px #e59200;
			list-style: none;
			margin: 2em 0 1em 0;
			padding: 2em 0 0 0;
			width: 100%;
			text-align: center;

		li {
		display: block;
		font-size: 0.9em;
		line-height: 1;
		margin-left: 1em;
		padding: 0 0 0 1em;
		margin-bottom: 2em;

		&:first-child {
		border-left: 0;
		margin-left: 0;
		padding-left: 0;
		}

		&:last-child {
		margin-bottom: 0;
		}

		a {
		color: inherit;
		border-bottom: none;
		}

		img {
		max-width: 100%;
		}
		}
		}
		}
		}

		@media screen and (max-width: $scherm-extrabreed) {
		#footer {
		margin-top: -6.5em;
		padding-top: 6.5em;
		}
		}

		@media screen and (max-width: $scherm-breed) {
		#footer {
		margin-top: -4.75em;
		padding-top: 4.75em;
		.inner {
		padding: 3em 3em 1em 3em;
		display: block;
		width: 100%;
		form {
		width: 100%;
		margin: 0 0 4em 0;
		}

		.contact {
		width: 100%;
		margin: 0 0 4em 0;
		}

		.copyright,
		.sponsors {
		margin: 4em 0 2em 0;
		}
		}
		}
		}

		@media screen and (max-width: $scherm-middel) {
		#footer {
		margin-top: -2.5em;
		padding-top: 2.5em;
		.inner {
		padding: 2em 2em 0.1em 2em;
		}

		form {
		margin: 0 0 3em 0;
		}

		.contact {
		margin: 0 0 3em 0;
		}
		}
		}

		@media screen and (max-width: $scherm-middelsmal) {
		#footer .inner {
		.copyright li,
		.sponsors li {
		border-left: 0;
		display: block;
		margin: 1em 0 0 0;
		padding-left: 0;
		&:first-child {
		margin-top: 0;
		}
		}
		}
		}

		@media screen and (max-width: $scherm-smal) {
		#footer .inner {
		padding: 2em 1.5em 0.1em 1.5em;
		}
		}



	</style>

	<main class="container-fluid p-3 min-vh-100">
		{% include 'melding.html.twig' %}
		<div class="cd-page-content voorpagina container px-0 ratio ratio-3x2">
			<div class="grid-container p-0 p-md-3">
				<div class="cell cell-posters ratio ratio-5x4">{{ render(path('csrdelft_voorpagina_posters')) }}</div>
				<div class="cell cell-forum cell-overflow">{{ render(path('csrdelft_voorpagina_forum')) }}</div>
				<div class="cell cell-agenda cell-overflow">{{ render(path('csrdelft_voorpagina_agenda')) }}</div>
				<div class="cell cell-civi-saldo position-relative">{{ render(path('csrdelft_voorpagina_civisaldo')) }}</div>
				<div class="cell cell-is-het-al">{{ render(path('csrdelft_voorpagina_ishetal')) }}</div>
				<div class="cell cell-verjaardagen cell-overflow">{{ render(path('csrdelft_voorpagina_verjaardagen')) }}</div>
				<div class="cell cell-foto-albums">{{ render(path('csrdelft_voorpagina_fotoalbum')) }}</div>
				<div class="cell cell-overig">{{ render(path('csrdelft_voorpagina_overig')) }}</div>
			</div>
		</div>
		<div class="container p-0 p-md-3 mt-5">
			{# TODO: advertenties #}
			<div class="cell cell-advertenties gap-2">
				{{ cms('voorpagina_advertenties') }}
			</div>
		</div>
	</main>


	<!-- Footer -->
	<div id="wrapper">
		<section id="footer">
			<div class="inner">
				<ul class="copyright">
					<li>&copy; {{ date().format('Y') }} - C.S.R. Delft - <a
							href="/download/Privacyverklaring%20C.S.R.%20Delft%20-%20Extern%20-%2025-05-2018.pdf">Privacy</a></li>
				</ul>
			</div>
		</section>
	</div>


{% endblock %}
